      <g class="sphere-arc">
        <circle cx="100" cy="100" r="96" fill="none"
          stroke="#38bdf8" stroke-width="1"
          stroke-dasharray="28 14" stroke-linecap="round" opacity=".4"/>
      </g>
    </svg>
    <!-- core -->
