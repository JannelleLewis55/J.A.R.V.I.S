      <div class="sphere-glow"></div>
      <span class="sphere-label">J.A.R.V.I.S</span>
    </div>
  </div>

  <!-- Audio meter (16 bars) -->
  <div class="meter-wrap" id="meter"></div>

  <!-- Status -->
