  // auto-resize textarea
  input.addEventListener('input', () => {
    input.style.height = 'auto';
    input.style.height = Math.min(input.scrollHeight, 180) + 'px';
  });

  // chip click → fill input or navigate
  document.querySelectorAll('.chip').forEach(chip => {
    chip.addEventListener('click', () => {
      if (chip.dataset.href) { window.location.href = chip.dataset.href; return; }
      input.value = chip.dataset.q;
      input.dispatchEvent(new Event('input'));
      input.focus();
    });
  });

  // submit → go to chat page, pass query in URL hash
  function submit() {
    const q = input.value.trim();
    if (!q) { input.focus(); return; }
    window.location.href = 'index.html#' + encodeURIComponent(q);
  }

  askBtn.addEventListener('click', submit);
  input.addEventListener('keydown', e => {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); submit(); }
  });
