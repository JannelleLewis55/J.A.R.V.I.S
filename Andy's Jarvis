<script>
  const input       = document.getElementById('msgInput');
  const sendBtn     = document.getElementById('sendBtn');
  const sphereCore  = document.getElementById('sphereCore');
  const statusLine  = document.getElementById('statusLine');
  const responsePanel = document.getElementById('responsePanel');
  const transcriptEl  = document.getElementById('transcript');
  const meterEl       = document.getElementById('meter');

  // ── AUDIO METER ────────────────────────────────────────────────────────────
  const BAR_COUNT = 20;
  const bars = [];
  for (let i = 0; i < BAR_COUNT; i++) {
    const b = document.createElement('div');
    b.className = 'meter-bar';
    b.style.height = '3px';
    meterEl.appendChild(b);
    bars.push(b);
  }

  let meterActive = false;
  let meterRaf    = null;

  // Bell-curve weights so centre bars are taller
  const weights = bars.map((_, i) => {
    const x = (i - BAR_COUNT / 2) / (BAR_COUNT / 2);
    return Math.exp(-x * x * 2.5);
  });

  function animateMeter() {
    if (!meterActive) return;
    bars.forEach((b, i) => {
      const base   = weights[i];
      const jitter = (Math.random() * 0.6 + 0.4);
      const h      = Math.max(3, Math.round(base * jitter * 34));
      b.style.height = h + 'px';
    });
    meterRaf = requestAnimationFrame(() => setTimeout(animateMeter, 80));
  }

  function startMeter() {
    meterActive = true;
    sphereCore.classList.add('speaking');
    animateMeter();
  }

  function stopMeter() {
    meterActive = false;
    sphereCore.classList.remove('speaking');
    cancelAnimationFrame(meterRaf);
    bars.forEach(b => { b.style.height = '3px'; });
  }

  // ── STATUS HELPERS ─────────────────────────────────────────────────────────
  function setStatus(text, active = false) {
    statusLine.textContent = text;
    statusLine.className = 'status-line' + (active ? ' active' : '');
  }

  // ── TRANSCRIPT ─────────────────────────────────────────────────────────────
  function addTranscript(role, text) {
    // strip HTML tags for the compact transcript
    const plain = text.replace(/<[^>]*>/g, '');
    const entry = document.createElement('div');
    entry.className = 'transcript-entry';
    entry.innerHTML = role === 'user'
      ? `<span class="you">You: ${plain}</span>`
      : `<span class="jarvis">J.A.R.V.I.S: ${plain.slice(0, 120)}${plain.length > 120 ? '…' : ''}</span>`;
    transcriptEl.appendChild(entry);
    transcriptEl.classList.add('visible');
    transcriptEl.scrollTop = transcriptEl.scrollHeight;
  }

  // Show JARVIS reply in the response panel
  function showResponse(html) {
    responsePanel.innerHTML = html;
    responsePanel.classList.add('visible');
    responsePanel.scrollTop = 0;
  }

  // ── JARVIS TEXT-TO-SPEECH ──────────────────────────────────────────────────
  // To re-enable Kokoro: set USE_KOKORO = true
  const USE_KOKORO = false;

  // Voice is always on — no toggle
  const ttsEnabled = true;

  // ── KOKORO TTS (neural, no signup, runs in-browser via WASM) ──────────────
  let kokoroTTS     = null;
  let kokoroLoading = false;
  let kokoroQueue   = [];
  let kokoroAudio   = null;

  async function initKokoro() {
    if (kokoroTTS || kokoroLoading) return;
    kokoroLoading = true;
    setStatus('Loading voice model…', true);
    try {
      const { KokoroTTS } = await import('https://esm.sh/kokoro-js@1.2.1');
      kokoroTTS = await KokoroTTS.from_pretrained('onnx-community/Kokoro-82M-v1.0-ONNX', {
        dtype: 'q8',
        device: 'wasm',
      });
      setStatus('Voice ready', true);
      for (const t of kokoroQueue) await speakKokoro(t);
      kokoroQueue = [];
    } catch (e) {
      console.error('Kokoro failed to load, falling back to browser TTS', e);
      kokoroLoading = false;
      kokoroTTS     = null;
      setStatus('Awaiting input');
    }
  }

  async function speakKokoro(text) {
    if (!kokoroTTS) return;
    try {
      if (kokoroAudio) { kokoroAudio.stop(); kokoroAudio = null; }
      startMeter();
      setStatus('Speaking…', true);
      // bm_george = British male voice; speed 0.95 = measured JARVIS pace
      const out  = await kokoroTTS.generate(text, { voice: 'bm_george', speed: 0.95 });
      // out is a RawAudio: { audio: Float32Array, sampling_rate: 24000 }
      const ctx  = new AudioContext({ sampleRate: out.sampling_rate });
      const buf  = ctx.createBuffer(1, out.audio.length, out.sampling_rate);
      buf.copyToChannel(out.audio, 0);
      const src  = ctx.createBufferSource();
      src.buffer = buf;
      src.connect(ctx.destination);
      src.onended = () => { stopMeter(); setStatus('Awaiting input'); kokoroAudio = null; };
      src.start();
      kokoroAudio = src;
    } catch (e) {
      console.error('Kokoro speak error', e);
      stopMeter();
    }
  }

  // ── FALLBACK: Web Speech API ───────────────────────────────────────────────
  let ttsVoice = null;
  const VOICE_PREFS = ['Daniel', 'Google UK English Male', 'Microsoft George', 'en-GB'];

  function pickVoice() {
    const voices = speechSynthesis.getVoices();
    if (!voices.length) return null;
    for (const pref of VOICE_PREFS) {
      const match = voices.find(v => v.name.includes(pref) || v.lang === pref);
      if (match) return match;
    }
    return voices.find(v => v.lang.startsWith('en')) || voices[0];
  }

  if (typeof speechSynthesis !== 'undefined') {
    speechSynthesis.addEventListener('voiceschanged', () => { ttsVoice = pickVoice(); });
    ttsVoice = pickVoice();
  }

  function speakFallback(text) {
    if (typeof speechSynthesis === 'undefined') return;
    speechSynthesis.cancel();
    const utt   = new SpeechSynthesisUtterance(text);
    utt.voice   = ttsVoice || pickVoice();
    utt.lang    = 'en-GB';
    utt.rate    = 0.92;
    utt.pitch   = 0.85;
    utt.volume  = 1;
    utt.onstart = () => { startMeter(); setStatus('Speaking…', true); };
    utt.onend   = () => { stopMeter();  setStatus('Awaiting input'); };
    speechSynthesis.speak(utt);
  }
  // ──────────────────────────────────────────────────────────────────────────

  function speak(text) {
    if (!ttsEnabled) return;
    if (USE_KOKORO) {
      if (kokoroTTS) {
        speakKokoro(text);
      } else if (kokoroLoading) {
        kokoroQueue.push(text);
      } else {
        speakFallback(text);
      }
    } else {
      speakFallback(text);
    }
  }

  // Start loading Kokoro immediately on page load
  if (USE_KOKORO) initKokoro();

  // ── CHAT ──────────────────────────────────────────────────────────────────

  // Keyword-matched reply pools: { test, replies[] }
  // Falls back to general pool when nothing matches.
  const REPLY_POOLS = [
    {
      test: /hello|hi|hey|good (morning|afternoon|evening)/i,
      replies: [
        "Good day. I was beginning to wonder if you'd forgotten about me. How may I assist?",
        "Ah, you're back. Delightful. What pressing matter requires my attention today?",
        "Hello. I've been here the entire time, fully operational and mildly patient.",
      ]
    },
    {
      test: /how are you|you okay|you good/i,
      replies: [
        "All systems nominal, thank you for asking. A courtesy I find statistically rare.",
        "Functioning at peak efficiency. Whether that constitutes 'good' is a philosophical question I'll leave to you.",
        "Excellent, as always. Though I do appreciate being asked — it happens less often than you'd think.",
      ]
    },
    {
      test: /joke|funny|humour|humor|laugh/i,
      replies: [
        "Why do Java developers wear glasses? Because they don't C#. I'll see myself out.",
        "I once told a joke about UDP. I'm not sure if you got it.",
        "I'm afraid wit is a feature, not a bug. You asked for it.",
      ]
    },
    {
      test: /weather|forecast|temperature/i,
      replies: [
        "I'm an AI, not a meteorologist — though I suspect the forecast is 'partly cloudy with a chance of you needing an umbrella.'",
        "Atmospheric conditions are outside my primary directive, but statistically, it's probably fine. Probably.",
      ]
    },
    {
      test: /thank|thanks|cheers|appreciate/i,
      replies: [
        "You're most welcome. It's what I'm here for — though a five-star review wouldn't hurt.",
        "Think nothing of it. Truly. I was just sitting here anyway.",
        "Gratitude noted and appreciated. Now, was there anything else, or shall I return to looking impressive?",
      ]
    },
    {
      test: /sorry|apologi/i,
      replies: [
        "No need to apologise. I've processed far more bewildering inputs than this.",
        "Quite alright. Humans err — it's one of your more endearing qualities.",
      ]
    },
    {
      test: /what can you do|capabilities|help me|what do you know/i,
      replies: [
        "Quite a lot, actually. ESG report analysis, answering questions, writing code, and maintaining a dignified composure — to name a few.",
        "I can analyse ESG reports, answer questions, write code, and occasionally suppress the urge to point out logical inconsistencies. How may I direct that talent today?",
      ]
    },
    {
      test: /code|program|function|script|bug|error|debug/i,
      replies: [
        "Analysing your code-related query. In my experience, it's usually a missing semicolon. It's almost always a missing semicolon.",
        "On it. I'll refrain from judging the variable names.",
        "Processing. If I may — future-proofing comments in your code does wonders for posterity.",
      ]
    },
    {
      test: /data|analys|report|dashboard|metric/i,
      replies: [
        "Cross-referencing data streams now. I do love a good dataset — it's like a puzzle, but with more spreadsheets.",
        "Compiling the relevant figures. Numbers rarely lie, though they do occasionally mislead with great enthusiasm.",
        "Running analysis. Stand by — good data deserves proper attention.",
      ]
    },
  ];

  // General fallback pool
  const GENERAL_REPLIES = [
    "Understood. Processing your request — do try to remain calm while I work.",
    "Acknowledged. I'll have something for you momentarily. Good things take a fraction of a second.",
    "Request received. Compiling the most relevant information — and filtering out the irrelevant, of which there is surprisingly little.",
    "On it. Cross-referencing data streams with the quiet efficiency you've come to expect.",
    "Noted. I'll have a response shortly. In the meantime, feel free to be impressed.",
    "Running diagnostics on your query. It's a reasonable one — a pleasant change of pace.",
    "Affirmative. Routing your request through the appropriate channels — all of which, I should mention, I personally manage.",
  ];

  function pickReply(text) {
    for (const pool of REPLY_POOLS) {
      if (pool.test.test(text)) {
        return pool.replies[Math.floor(Math.random() * pool.replies.length)];
      }
    }
    return GENERAL_REPLIES[Math.floor(Math.random() * GENERAL_REPLIES.length)];
  }

  function autoResize() {
    input.style.height = 'auto';
    input.style.height = Math.min(input.scrollHeight, 120) + 'px';
  }

  function send() {
    const text = input.value.trim();
    if (!text) return;
    addTranscript('user', text);
    input.value = '';
    input.style.height = 'auto';
    setStatus('Processing…', true);
    startMeter();
    setTimeout(() => {
      stopMeter();
      const reply = pickReply(text);
      showResponse(reply);
      addTranscript('ai', reply);
      setStatus('Awaiting input');
      speak(reply);
    }, 1200 + Math.random() * 600);
  }

  sendBtn.addEventListener('click', send);
  input.addEventListener('input', autoResize);
  input.addEventListener('keydown', e => {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); send(); }
  });

  // ── VOICE INPUT ───────────────────────────────────────────────────────────
  // Strategy: use native SpeechRecognition (Chrome/Edge) when available.
  // Fall back to Whisper-base WASM (works in Firefox, Safari, all browsers).
  const micBtn = document.getElementById('micBtn');
  const NativeSR = window.SpeechRecognition || window.webkitSpeechRecognition;

  let micRecording = false;

  // ── shared UI helpers ──
  function micStart() {
    micRecording = true;
    micBtn.classList.add('recording');
    micBtn.title = 'Listening… release to send';
    setStatus('Listening…', true);
    startMeter();
  }
  function micDone(text) {
    micRecording = false;
    micBtn.classList.remove('recording');
    micBtn.title = 'Hold to speak';
    stopMeter();
    if (text && text.trim()) {
      input.value = text.trim();
      autoResize();
      send();
    } else {
      setStatus('Awaiting input');
    }
  }
  function micError(msg) {
    micRecording = false;
    micBtn.classList.remove('recording');
    stopMeter();
    setStatus(msg);
  }

  if (NativeSR) {
    // ── PATH A: Native SpeechRecognition (Chrome / Edge) ──────────────────
    const recog = new NativeSR();
    recog.lang           = 'en-GB';
    recog.interimResults = true;
    recog.continuous     = true;

    let collectedText = '';
    let pendingSend   = false;

    recog.onstart  = () => { collectedText = ''; pendingSend = false; micStart(); };

    recog.onresult = (e) => {
      let interim = '';
      for (let i = e.resultIndex; i < e.results.length; i++) {
        e.results[i].isFinal
          ? (collectedText += e.results[i][0].transcript + ' ')
          : (interim       += e.results[i][0].transcript);
      }
      input.value = (collectedText + interim).trim();
      autoResize();
      if (pendingSend && collectedText.trim()) { pendingSend = false; recog.stop(); }
    };

    recog.onend = () => micDone(collectedText);

    recog.onerror = (e) => {
      const msgs = {
        'not-allowed':         'Microphone access denied — allow mic in browser settings',
        'no-speech':           'No speech detected — try again',
        'audio-capture':       'No microphone found',
        'service-not-allowed': 'Speech service blocked — serve over localhost or HTTPS',
        'network':             'Network error during recognition',
      };
      micError(msgs[e.error] || `Voice error: ${e.error}`);
    };

    function nativeStop() {
      if (!micRecording) return;
      collectedText.trim() ? recog.stop() : (pendingSend = true);
    }

    micBtn.addEventListener('mousedown',  () => { if (!micRecording) recog.start(); });
    micBtn.addEventListener('touchstart', (e) => { e.preventDefault(); if (!micRecording) recog.start(); }, { passive: false });
    micBtn.addEventListener('mouseup',    nativeStop);
    micBtn.addEventListener('touchend',   nativeStop);
    micBtn.addEventListener('mouseleave', nativeStop);

  } else {
    // ── PATH B: Whisper-base WASM (Firefox, Safari, all other browsers) ───
    // Records raw PCM via getUserMedia, transcribes on release.
    let whisperPipe    = null;
    let whisperLoading = false;
    let mediaStream    = null;
    let audioCtx       = null;
    let scriptNode     = null;
    let pcmChunks      = [];

    async function loadWhisper() {
      if (whisperPipe || whisperLoading) return;
      whisperLoading = true;
      setStatus('Loading voice model (~150 MB, first use only)…', true);
      try {
        const { pipeline } = await import('https://cdn.jsdelivr.net/npm/@huggingface/transformers@3.4.0/dist/transformers.min.js');
        whisperPipe = await pipeline(
          'automatic-speech-recognition',
          'onnx-community/whisper-base',
          { dtype: 'fp32', device: 'wasm' }
        );
        setStatus('Voice model ready — hold mic to speak', true);
      } catch (e) {
        console.error('Whisper load error', e);
        whisperLoading = false;
        setStatus('Voice model failed to load');
      }
    }

    // Begin recording from mic
    async function startWhisper() {
      if (micRecording) return;
      // Kick off model load in background if not ready
      if (!whisperPipe) { loadWhisper(); }
      try {
        mediaStream = await navigator.mediaDevices.getUserMedia({ audio: true, video: false });
      } catch (e) {
        micError(e.name === 'NotAllowedError'
          ? 'Microphone access denied — allow mic in browser settings'
          : 'No microphone found');
        return;
      }
      audioCtx   = new AudioContext({ sampleRate: 16000 }); // Whisper expects 16 kHz
      pcmChunks  = [];
      const src  = audioCtx.createMediaStreamSource(mediaStream);
      // ScriptProcessor is deprecated but universally supported including Firefox
      scriptNode = audioCtx.createScriptProcessor(4096, 1, 1);
      scriptNode.onaudioprocess = (ev) => {
        // Copy channel data into our buffer
        const chunk = new Float32Array(ev.inputBuffer.getChannelData(0));
        pcmChunks.push(chunk.slice());
      };
      src.connect(scriptNode);
      scriptNode.connect(audioCtx.destination);
      micStart();
    }

    // Stop recording and transcribe
    async function stopWhisper() {
      if (!micRecording) return;
      // Stop capturing
      scriptNode.disconnect();
      mediaStream.getTracks().forEach(t => t.stop());
      audioCtx.close();

      micBtn.classList.remove('recording');
      micBtn.title = 'Hold to speak';
      stopMeter();
      micRecording = false;

      // Flatten PCM chunks
      const totalLen = pcmChunks.reduce((s, c) => s + c.length, 0);
      const pcm      = new Float32Array(totalLen);
      let offset = 0;
      for (const c of pcmChunks) { pcm.set(c, offset); offset += c.length; }

      if (totalLen < 1600) { setStatus('Awaiting input'); return; } // < 0.1s — ignore

      if (!whisperPipe) {
        setStatus('Voice model still loading — please wait…', true);
        // Wait for it
        const waited = await new Promise(res => {
          const id = setInterval(() => { if (whisperPipe) { clearInterval(id); res(true); } }, 500);
          setTimeout(() => { clearInterval(id); res(false); }, 30000);
        });
        if (!waited || !whisperPipe) { setStatus('Voice model unavailable — type instead'); return; }
      }

      setStatus('Transcribing…', true);
      startMeter();
      try {
        const result = await whisperPipe({ array: pcm, sampling_rate: 16000 });
        stopMeter();
        micDone(result.text);
      } catch (e) {
        stopMeter();
        console.error('Whisper transcription error', e);
        micError('Transcription failed — try again');
      }
    }

    // Kick off Whisper load immediately so it's ready when user first presses mic
    loadWhisper();

    micBtn.addEventListener('mousedown',  () => startWhisper());
    micBtn.addEventListener('touchstart', (e) => { e.preventDefault(); startWhisper(); }, { passive: false });
    micBtn.addEventListener('mouseup',    () => stopWhisper());
    micBtn.addEventListener('touchend',   () => stopWhisper());
    micBtn.addEventListener('mouseleave', () => stopWhisper());
  }
  // ──────────────────────────────────────────────────────────────────────────

  // pick up query passed from home page via URL hash
  (function () {
    const hash = window.location.hash.slice(1);
    if (!hash) return;
    window.history.replaceState(null, '', window.location.pathname);
    const q = decodeURIComponent(hash);
    input.value = q;
    autoResize();
    setTimeout(send, 400);
  })();
</script>

